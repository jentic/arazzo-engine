{
  "arazzo": "1.0.1",
  "info": {
    "title": "Draft List and Download Tender Documents",
    "version": "1.0.0",
    "summary": "Draft workflow to verify list and download steps work correctly",
    "description": "Lists tender documents, uses Mistral AI to extract the first document ID, and downloads the first one to verify document ID extraction works. Currently only retrieves one document ID from the HTML content from ETenders and downloads this. Using a specific test tender ID to verify the workflow works."
  },
  "sourceDescriptions": [
    {
      "name": "ETenders API",
      "url": "./openapi/etenders-openapi.json",
      "type": "openapi"
    },
    {
      "name": "Mistral AI",
      "url": "./openapi/mistral-openapi.json",
      "type": "openapi"
    }
  ],
  "workflows": [
    {
      "workflowId": "testListAndDownloadTenderDocument",
      "summary": "Test list and download tender documents",
      "description": "Lists tender documents, extracts first document ID, and downloads it",
      "inputs": {
        "type": "object",
        "properties": {
          "resourceId": {
            "type": "string",
            "description": "Unique 7-digit identifier for the tender",
            "example": "7641353",
            "pattern": "^[0-9]{7}$"
          },
          "isContract": {
            "type": "string",
            "description": "Optional flag, typically set to null for tender documents",
            "example": "null"
          }
        },
        "required": [
          "resourceId"
        ]
      },
      "steps": [
        {
          "stepId": "listTenderDocuments",
          "description": "List all documents available for the tender to get document IDs",
          "operationId": "listTenderDocuments",
          "sourceDescription": "ETenders API",
          "parameters": [
            {
              "name": "resourceId",
              "in": "query",
              "value": "$inputs.resourceId"
            }
          ],
          "successCriteria": [
            {
              "condition": "$statusCode == 200"
            }
          ],
          "outputs": {
            "htmlContent": "$response.body"
          }
        },
        {
          "stepId": "extractDocumentId",
          "description": "Extract the first document ID from HTML using Mistral AI LLM",
          "operationId": "chat_completion_v1_chat_completions_post",
          "sourceDescription": "Mistral AI",
          "requestBody": {
            "contentType": "application/json",
            "payload": {
              "model": "mistral-large-latest",
              "messages": [
                {
                  "role": "system",
                  "content": "You will receive HTML from the listTenderDocuments step. Find the first occurrence of the exact substring downloadDocForAnonymous(' and output only the 7 digits that immediately follow (inside the quotes). Your entire response must be exactly those 7 digits—no quotes, spaces, or other text. Do not guess: only output digits that appear in the HTML you receive."
                },
                {
                  "role": "user",
                  "content": "$steps.listTenderDocuments.outputs.htmlContent"
                }
              ],
              "temperature": 0,
              "max_tokens": 15
            }
          },
          "successCriteria": [
            {
              "condition": "$statusCode == 200"
            },
            {
              "condition": "$response.body.choices != null"
            },
            {
              "condition": "$response.body.choices.0.message.content != null"
            }
          ],
          "outputs": {
            "firstDocumentId": "$response.body.choices.0.message.content"
          },
          "onFailure": [
            {
              "name": "extractionFailed",
              "type": "end",
              "criteria": [
                {
                  "condition": "$statusCode >= 400"
                }
              ]
            }
          ]
        },
        {
          "stepId": "downloadTenderDocument",
          "description": "Download the actual binary file content for a specific tender document",
          "operationId": "downloadTenderDocument",
          "sourceDescription": "ETenders API",
          "parameters": [
            {
              "name": "documentId",
              "in": "query",
              "value": "$steps.extractDocumentId.outputs.firstDocumentId"
            },
            {
              "name": "resourceId",
              "in": "query",
              "value": "$inputs.resourceId"
            },
            {
              "name": "isContract",
              "in": "query",
              "value": "$inputs.isContract"
            }
          ],
          "successCriteria": [
            {
              "condition": "$statusCode == 200"
            }
          ],
          "outputs": {
            "fileContent": "$response.body",
            "contentType": "$response.header.Content-Type",
            "contentDisposition": "$response.header.Content-Disposition",
            "contentLength": "$response.header.Content-Length"
          }
        }
      ],
      "outputs": {
        "resourceId": "$inputs.resourceId",
        "documentId": "$steps.extractDocumentId.outputs.firstDocumentId",
        "contentDisposition": "$steps.downloadTenderDocument.outputs.contentDisposition",
        "contentType": "$steps.downloadTenderDocument.outputs.contentType",
        "contentLength": "$steps.downloadTenderDocument.outputs.contentLength"
      }
    }
  ]
}
